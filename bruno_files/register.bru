meta {
  name: register
  type: http
  seq: 1
}

post {
  url: http://localhost:8080/api/auth/register
  body: json
  auth: inherit
}

body:json {
  {
      "email": "test@example.com",
      "password": "password123",
      "matchingPassword": "password123"
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
